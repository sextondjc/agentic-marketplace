{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/agent-plugin-integrity/plugin-manifest.schema.json",
  "title": "Agent Plugin Integrity Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pluginId",
    "pluginVersion",
    "sourceCommit",
    "digestAlgorithm",
    "generatedAtUtc",
    "artifactEntries",
    "aggregateDigest"
  ],
  "properties": {
    "pluginId": {
      "type": "string",
      "minLength": 1
    },
    "pluginVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "sourceCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,64}$"
    },
    "digestAlgorithm": {
      "type": "string",
      "const": "SHA-256"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "artifactEntries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "aggregateDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
